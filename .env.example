# API Keys (Provide at least one of these to run the system)
GEMINI_API_KEY=your_gemini_api_key_here
# OR
OPENAI_API_KEY=your_openai_api_key_here

# Provider Configuration: gemini or openai
# If empty, the system automatically detects which key is present.
EMBEDDING_PROVIDER=gemini
LLM_PROVIDER=gemini

# Specific Models (Optional - system has defaults)
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
GEMINI_LLM_MODEL=gemini-1.5-flash
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini

# Grounded LLM answering thresholds
CONFIDENCE_THRESHOLD=0.45

# Database Configuration (Optional - defaults to local python storage)
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_PATH=./qdrant_db
